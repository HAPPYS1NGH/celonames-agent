# Celo RPC endpoint (default: public Forno node)
CELO_RPC_URL=https://forno.celo.org

# Agent's wallet private key — pays gas for registrations (keep secret)
PRIVATE_KEY=0x...

# Agent's public wallet address — clients send $1.50 USDC here
AGENT_WALLET_ADDRESS=0x...

# HTTP server port (default: 3000)
PORT=3000

# Public base URL of your deployed agent (used in agent-registration.json)
BASE_URL=https://celonames.example.com

# Only needed for: deno task register (ERC-8004 on-chain registration)
PINATA_JWT=...
